#!/bin/sh
APPNAME="QCTools"
SIGNATURE="MediaArea.net"
BUNDLEID="net.mediaarea.qctools.mac"

DMG="tmp-${APPNAME}.dmg"
FILES="tmp-${APPNAME}"

# Create the package
rm -rf "${FILES}"
rm -f "${DMG}"
rm -f "${APPNAME}.dmg"

mkdir "${FILES}"
mkdir "${FILES}/.background"
cp -R "../QtCreator/build/qctools-gui/${APPNAME}.app" "${FILES}/"

