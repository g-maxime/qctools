#        plutil -replace CFBundleIdentifier -string "${BUNDLEID}" "${LIB}/Resources/Info.plist"
#    fi

#    codesign -f -s "Developer ID Application: ${SIGNATURE}" -i "${BUNDLEID}" --verbose "${LIB}"
#done

#for LIB in /Users/jerome/build/snapshots/qctools/qctools/Project/Mac/tmp-QCTools/QCTools.app/Contents/PlugIns/*/* ; do
